---
import { navigation } from '../data/navigation';
import { site } from '../data/site';
---

<footer class="footer">
  <div class="container footer__grid">
    <div>
      <p class="footer__brand">{site.companyName}</p>
      <p>Personal heating and air-conditioning service for the South Bay since {site.establishedYear}.</p>
      <p><a href={`tel:${site.phoneUri}`} data-ga-event="phone_click" data-ga-placement="footer">{site.phoneDisplay}</a><br /><a href={`mailto:${site.email}`}>{site.email}</a></p>
    </div>
    <div>
      <h2>Contact</h2>
      <address>{site.address.streetAddress}<br />{site.address.addressLocality}, {site.address.addressRegion} {site.address.postalCode}</address>
      <p>Fax: {site.faxDisplay}</p>
      {site.socialLinks.map((link) => <p><a href={link.href} rel="external">{link.label}<span class="visually-hidden"> (opens Yelp)</span></a></p>)}
    </div>
    <div>
      <h2>Explore</h2>
      <ul>{navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}<li><a href="/privacy/">Privacy</a></li></ul>
    </div>
  </div>
  <div class="container footer__legal">
    <p>&copy; {new Date().getFullYear()} {site.companyName}</p>
    <p class="license">{site.licenseLabel}</p>
  </div>
</footer>

<style>
  .footer { padding-top: var(--space-8); color: #d7e0e7; background: var(--color-navy-950); }
  .footer__grid { display: grid; grid-template-columns: 1.4fr 1fr .7fr; gap: var(--space-7); }
  .footer h2 { color: var(--color-white); font-family: var(--font-sans); font-size: 1rem; letter-spacing: .08em; text-transform: uppercase; }
  .footer a { color: var(--color-white); }
  .footer address { font-style: normal; }
  .footer ul { padding: 0; list-style: none; }
  .footer li + li { margin-top: .35rem; }
  .footer__brand { color: var(--color-white); font-family: var(--font-display); font-size: var(--step-2); font-weight: 800; }
  .footer__legal { display: flex; margin-top: var(--space-7); padding-block: var(--space-5); border-top: 1px solid #385063; justify-content: space-between; gap: var(--space-5); font-size: .78rem; }
  .footer__legal p { margin: 0; }
  .license { max-width: 42rem; text-align: right; }
  @media (max-width: 46rem) {
    .footer__grid { grid-template-columns: 1fr; gap: var(--space-5); }
    .footer__legal { display: block; }
    .license { margin-top: var(--space-3) !important; text-align: left; }
  }
</style>
