---
interface Props { title: string; summary: string; icon: 'heat' | 'cool' | 'replace' | 'repair' | 'home' | 'control'; }
const { title, summary, icon } = Astro.props;
const paths = {
  heat: 'M12 2c1 4-2 5-2 8 0 2 1 3 2 4 2-2 4-4 3-7 4 3 5 7 3 11-2 4-8 4-10 0-2-4-1-8-1-9 0 1-2 3-2 6 0 2 1 4 3 5',
  cool: 'M12 2v20M4.2 6.5l15.6 11M4.2 17.5l15.6-11M8 4l4 3 4-3M8 20l4-3 4 3M3 10l4 2-4 2M21 10l-4 2 4 2',
  replace: 'M4 7h13l-3-3M20 17H7l3 3M17 7l-3 3M7 17l3-3',
  repair: 'M14 6a4 4 0 0 0-5-4l2.2 2.2-3 3L6 5a4 4 0 0 0 4 5L4 16a2 2 0 1 0 4 4l6-6a4 4 0 0 0 5-5l-2.2-2.2-3 3L14 6Z',
  home: 'M3 11 12 3l9 8v10h-6v-6H9v6H3Z',
  control: 'M4 6h10M18 6h2M4 12h2M10 12h10M4 18h9M17 18h3M16 4v4M8 10v4M15 16v4',
};
---

<article class="card service-card">
  <div class="icon-box" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={paths[icon]} /></svg></div>
  <h3>{title}</h3>
  <p>{summary}</p>
  <slot />
</article>
