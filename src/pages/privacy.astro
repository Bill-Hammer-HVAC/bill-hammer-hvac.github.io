---
import { getEntry, render } from 'astro:content';
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
const page = await getEntry('pages', 'privacy');
if (!page) throw new Error('Missing privacy content');
const { Content } = await render(page);
---
<BaseLayout title={page.data.title} description={page.data.description} canonicalPath="/privacy/"><PageHero heading={page.data.heading} intro={page.data.intro} /><section class="section section--white"><article class="container prose"><Content /><p><small>Last updated: July 19, 2026</small></p></article></section></BaseLayout>
