---
import { Image } from 'astro:assets';
import { getCollection, getEntry, render } from 'astro:content';
import billHammer from '../assets/legacy/bill-hammer.jpg';
import CallToAction from '../components/CallToAction.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { site } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';

const page = await getEntry('pages', 'home');
if (!page) throw new Error('Missing home content');
const { Content: HomeContent } = await render(page);
const services = (await getCollection('services')).filter((item) => item.data.featured).sort((a, b) => a.data.order - b.data.order);
const testimonials = (await getCollection('testimonials')).filter((item) => item.data.featured).sort((a, b) => a.data.order - b.data.order).slice(0, 3);
const renderedTestimonials = await Promise.all(testimonials.map(async (item) => ({ item, Content: (await render(item)).Content })));
---

<BaseLayout title={page.data.title} description={page.data.description} canonicalPath="/">
  <Hero eyebrow={page.data.eyebrow} heading={page.data.heading} intro={page.data.intro ?? ''} />

  <section class="section section--white" aria-labelledby="value-heading">
    <div class="container value-grid">
      <div><p class="eyebrow">Local service, clearly explained</p><h2 id="value-heading">Comfort work built around your property</h2></div>
      <div class="lede"><p>From a new central system to a repair or equipment change-out, Hammer keeps the conversation direct. You can call Bill, explain what is happening, and arrange an in-home estimate.</p></div>
    </div>
  </section>

  <section class="section section--sand" aria-labelledby="services-heading">
    <div class="container">
      <p class="eyebrow">Heating and cooling services</p>
      <div class="section-heading"><h2 id="services-heading">Core HVAC services</h2><a class="text-link" href="/services/">View every service</a></div>
      <div class="grid grid--3">
        {services.map((service) => <ServiceCard title={service.data.title} summary={service.data.summary} icon={service.data.icon} />)}
      </div>
    </div>
  </section>

  <section class="section section--white" aria-labelledby="why-heading">
    <div class="container split-grid">
      <div><p class="eyebrow">Why call Hammer?</p><h2 id="why-heading">Experience and personal service</h2><p class="lede">The company’s public story has centered on straightforward HVAC work and direct customer relationships since {site.establishedYear}.</p></div>
      <ul class="trust-list">
        <li>Serving the South Bay since {site.establishedYear}</li>
        <li>Founded by and personally associated with Bill Hammer</li>
        <li>Free in-home estimates</li>
        <li>Senior discounts</li>
        <li>Referrals available upon request</li>
      </ul>
    </div>
  </section>

  <section class="section section--navy" aria-labelledby="owner-heading">
    <div class="container owner-grid">
      <div class="owner-photo">
        <Image src={billHammer} alt="Bill Hammer beside an outdoor air-conditioning condenser" widths={[480, 720, 960]} sizes="(max-width: 48rem) 100vw, 45vw" format="webp" quality={78} />
      </div>
      <div><p class="eyebrow">Meet the owner</p><h2 id="owner-heading">A South Bay business since {site.establishedYear}</h2><div class="owner-copy"><HomeContent /></div><a class="button button--light" href="/about/">Learn more about Hammer</a></div>
    </div>
  </section>

  <section class="section section--sand" aria-labelledby="testimonials-heading">
    <div class="container">
      <p class="eyebrow">From longtime customers</p>
      <div class="section-heading"><h2 id="testimonials-heading">Customer testimonials</h2><a class="text-link" href="/testimonials/">Read all testimonials</a></div>
      <div class="grid grid--3">
        {renderedTestimonials.map(({ item, Content }) => <TestimonialCard names={item.data.names} location={item.data.location} role={item.data.role}><Content /></TestimonialCard>)}
      </div>
    </div>
  </section>

  <section class="section section--white" aria-labelledby="area-heading">
    <div class="container area-grid"><div><p class="eyebrow">Local service area</p><h2 id="area-heading">Serving the South Bay</h2></div><div><p class="lede">Hammer Heating and Air Conditioning serves the South Bay from Redondo Beach. Call to confirm whether your property is within the current service area.</p><a class="text-link" href={`tel:${site.phoneUri}`} data-ga-event="phone_click" data-ga-placement="service_area">Ask about your location</a></div></div>
  </section>

  <CallToAction placement="homepage_bottom" />
</BaseLayout>

<style>
  .value-grid, .split-grid, .area-grid { display: grid; grid-template-columns: .9fr 1.1fr; align-items: start; gap: var(--space-8); }
  .value-grid h2, .split-grid h2, .area-grid h2 { margin-bottom: 0; }
  .section-heading { display: flex; margin-bottom: var(--space-6); align-items: end; justify-content: space-between; gap: var(--space-5); }
  .section-heading h2 { margin: 0; }
  .owner-grid { display: grid; grid-template-columns: minmax(0, .9fr) minmax(0, 1.1fr); align-items: center; gap: var(--space-8); }
  .owner-photo { overflow: hidden; aspect-ratio: 4 / 3; border: .5rem solid var(--color-white); box-shadow: var(--shadow-lg); }
  .owner-photo :global(picture) { display: block; height: 100%; }
  .owner-photo :global(img) { width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .owner-copy { margin-bottom: var(--space-5); color: #d7e2e9; font-size: var(--step-1); }
  @media (max-width: 48rem) { .value-grid, .split-grid, .area-grid, .owner-grid { grid-template-columns: 1fr; gap: var(--space-5); } .section-heading { display: block; } .section-heading .text-link { display: inline-block; margin-top: var(--space-2); } }
</style>
